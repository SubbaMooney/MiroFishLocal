# ===== Flask SECRET_KEY (Pflicht) =====
# Wird für Session/Cookie-Signaturen verwendet. KEIN Default-Fallback mehr
# — der Backend-Start schlägt fehl, wenn dieser Wert nicht gesetzt ist.
# Generieren via: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_64_hex_string

# ===== MiroFish API-Key (Pflicht, Auth-Middleware C1) =====
# Wird vom Backend in einem before_request-Hook gegen den X-API-Key-Header
# constant-time geprueft. Mindest-Entropie: 32 Zeichen. /health und
# CORS-Preflight (OPTIONS) sind ausgenommen. Frontend setzt den Key per
# Axios-Interceptor aus VITE_MIROFISH_API_KEY (siehe frontend/.env).
# Generieren via: python -c "import secrets; print(secrets.token_hex(32))"
MIROFISH_API_KEY=replace_with_random_64_hex_string

# ===== LLM-Provider (Pflicht) =====
# MiroFish ist provider-agnostisch und funktioniert mit jedem
# OpenAI-SDK-kompatiblen Endpoint. Trage hier den LLM-Provider deiner Wahl ein.
#
# Beispiele (NICHT empfohlen oder bevorzugt — nur Format-Referenz):
#
#   OpenAI:
#     LLM_API_KEY=sk-...
#     LLM_BASE_URL=https://api.openai.com/v1
#     LLM_MODEL_NAME=gpt-4o-mini
#     EMBED_MODEL_NAME=text-embedding-3-small
#     EMBED_DIM=1536
#
#   Lokal Ollama (LLM-Cost = 0, dafür GPU/CPU-Zeit):
#     1. ollama pull qwen2.5:7b
#     2. ollama pull nomic-embed-text
#     3. ollama serve   (Default-Port 11434, OpenAI-API auf /v1)
#     LLM_API_KEY=ollama   (egal welcher String, wird ignoriert)
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_MODEL_NAME=qwen2.5:7b
#     EMBED_API_KEY=ollama
#     EMBED_BASE_URL=http://localhost:11434/v1
#     EMBED_MODEL_NAME=nomic-embed-text
#     EMBED_DIM=768
#
#   Anderer Anbieter: jeder OpenAI-SDK-kompatible Endpoint
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=<your_llm_base_url>
LLM_MODEL_NAME=<your_model_name>

# ===== LightRAG / GraphRAG-Konfiguration =====
# Embedding-Provider faellt auf die LLM_*-Variablen oben zurueck, sofern
# nicht hier separat gesetzt. EMBED_MODEL_NAME und EMBED_DIM sind Pflicht.
EMBED_MODEL_NAME=<your_embedding_model>
EMBED_DIM=1024
#EMBED_API_KEY=<your_embed_api_key>      # default: LLM_API_KEY
#EMBED_BASE_URL=<your_embed_base_url>    # default: LLM_BASE_URL
#LIGHTRAG_WORKING_DIR_BASE=backend/uploads/lightrag

# ===== LightRAG Cost-Optimization-Knobs (optional, Defaults schon kosten-optimiert) =====
# Senken die LLM-Cost pro indexiertem PDF deutlich (Echt-Spike: ~2x weniger
# am Mini-Korpus, extrapoliert ~10-100x bei 10MB-PDFs). Bei Quality-Issues
# auf konservativere Werte zurueck.
#LIGHTRAG_CHUNK_TOKEN_SIZE=5000           # LightRAG-default 1200
#LIGHTRAG_CHUNK_OVERLAP_TOKEN_SIZE=200    # LightRAG-default 100
#LIGHTRAG_MAX_GLEANING=0                  # 0=Single-Pass; LightRAG-default 1
#LIGHTRAG_MAX_EXTRACT_INPUT_TOKENS=8000
#LIGHTRAG_DROP_EXAMPLES=true              # Few-Shot-Examples raus (Risiko: LLM-Output-Format)
#DEFAULT_CHUNK_SIZE=5000                  # MiroFish-side Chunk-Size
#DEFAULT_CHUNK_OVERLAP=200

# ===== Graph-Memory-Updater Throttling (optional, Defaults aggressiv) =====
# Bei LightRAG entspricht jeder Insert einer vollen LLM-Extraktion. Daher
# senken die Defaults die Insert-Rate ca. 60x vs. Zep-Originale.
#GRAPH_MEMORY_BATCH_SIZE=50               # vorher hardcoded 5
#GRAPH_MEMORY_SEND_INTERVAL=30.0          # vorher hardcoded 0.5

# ===== 加速 LLM 配置（可選）=====
# Optional 2. LLM-Endpoint fuer schnelle/billige Calls. Wenn ungenutzt,
# Variablen ganz entfernen — leere Strings werden NICHT als "deaktiviert"
# behandelt.
#LLM_BOOST_API_KEY=your_api_key_here
#LLM_BOOST_BASE_URL=your_base_url_here
#LLM_BOOST_MODEL_NAME=your_model_name_here
