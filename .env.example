# ===== Flask SECRET_KEY (Pflicht) =====
# Wird für Session/Cookie-Signaturen verwendet. KEIN Default-Fallback mehr
# — der Backend-Start schlägt fehl, wenn dieser Wert nicht gesetzt ist.
# Generieren via: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_64_hex_string

# ===== LLM-Provider (Pflicht) =====
# MiroFish ist provider-agnostisch und funktioniert mit jedem
# OpenAI-SDK-kompatiblen Endpoint. Trage hier den LLM-Provider deiner Wahl ein.
# Beispiele (NICHT empfohlen oder bevorzugt — nur Format-Referenz):
#   OpenAI:      LLM_BASE_URL=https://api.openai.com/v1                   LLM_MODEL_NAME=gpt-4o-mini
#   Lokal Ollama: LLM_BASE_URL=http://localhost:11434/v1                   LLM_MODEL_NAME=qwen2.5:7b
#   Anderer Anbieter: jeder OpenAI-SDK-kompatible Endpoint
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=<your_llm_base_url>
LLM_MODEL_NAME=<your_model_name>

# ===== ZEP記憶圖譜配置 =====
# 每月免費額度即可支撐簡單使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== LightRAG / GraphRAG-Konfiguration (Phase 1 Zep-Migration) =====
# Alle Werte sind optional. Sobald MiroFish auf LightRAG umgestellt ist
# (Phase 2-5), werden EMBED_MODEL_NAME und EMBED_DIM zur Pflicht.
# Embedding-Provider fällt auf die LLM_*-Variablen oben zurück, sofern
# nicht hier separat gesetzt.
#LIGHTRAG_WORKING_DIR_BASE=backend/uploads/lightrag   # default
#EMBED_API_KEY=<your_embed_api_key>                   # default: LLM_API_KEY
#EMBED_BASE_URL=<your_embed_base_url>                 # default: LLM_BASE_URL
#EMBED_MODEL_NAME=<your_embedding_model>              # provider-spezifisch
#EMBED_DIM=1024                                       # default: 1024

# ===== 加速 LLM 配置（可選）=====
# 注意如果不使用加速配置，env文件中就不要出現下面的配置項
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
